window-width = 120
window-height = 30

window-inherit-working-directory = false

font-family = "JetBrainsMono Nerd Font Mono"
font-family = "D2Coding"
font-size = 13
font-style = SemiBold
font-style-bold = Bold

theme = "pastel-pink"

background-opacity = 0.9
background-blur = true

macos-option-as-alt = "left"
